# =============================================================================
# n8n Self-Hosted AI Starter Kit - Environment Variables
# =============================================================================
# 사용법:
#   1. 이 파일을 .env로 복사: cp .env.example .env
#   2. 아래 빈 값들을 채워 넣기 (openssl rand -hex 32 명령어로 키 생성)
# =============================================================================

# PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=           # 직접 설정 (예: my_secure_password)
POSTGRES_DB=n8n

# n8n 보안 키 (각각 openssl rand -hex 32 로 생성)
N8N_ENCRYPTION_KEY=
N8N_USER_MANAGEMENT_JWT_SECRET=

# Ollama - Mac 네이티브 앱 연결 (Docker → 호스트 Mac 통신)
# Ollama 앱을 Mac에서 실행하면 host.docker.internal:11434 로 접근 가능
OLLAMA_HOST=host.docker.internal:11434

# Python Task Runner 인증 토큰 (n8n ↔ n8n-runners 간 통신)
# openssl rand -hex 32 로 생성
N8N_RUNNERS_AUTH_TOKEN=
